# OS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Source documents — copyrighted, obtain separately
sources/*
!sources/bas_short_*.csv

# All data/ content is copyrighted or derived from copyrighted sources — not for distribution.
# Exception: KJV translation is public domain and committed.
# Exception: patches.json is the developer correction layer — short text snippets, committed.
# Exception: corrections.json supersedes patches.json — single versioned correction manifest.
data/*
!data/translations/
data/translations/*
!data/translations/kjv/
!data/patches.json
!data/corrections.json

boneyard/data/

# Local secrets — never commit
.env

# Claude Code — machine-local settings only; shared settings (.claude/settings.json etc.) are tracked
.claude/settings.local.json

# Design scratch space — docs/ is the tracked home for design docs
redesign/

# Dead code kept for local reference
boneyard/

# Local Netlify folder
.netlify

# Generated build output — produced by `make build`, never committed
dist/

# Capacitor — native build artifacts (ios/ and android/ source is tracked; build outputs excluded)
ios/App/Pods/
ios/App/.build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/xcuserdata/
android/.gradle/
android/build/
android/app/build/
android/local.properties
# Generated web assets synced into native projects by `npx cap sync` — contain copyrighted data
ios/App/App/public/
android/app/src/main/assets/public/

# Node / Playwright
node_modules/
playwright-report/
test-results/

# Golden snapshot files — derived from copyrighted liturgical content, not for distribution
e2e/testdata/
tests/fixtures/book/

# Scraper caches — local state, not committed
tools/.scrape_cache.json
tools/.daily_cache/

# Generated audit artefacts — CLI run outputs and comparison reports
audit/
tools/extract_audit_report.txt
.deploy-latest
