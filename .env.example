# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# AWS — required for make deploy-staging / make promote
# BUCKET=<s3-bucket-name>
# CF_DISTRIBUTION_ID=<production-cloudfront-distribution-id>
# STAGING_DOMAIN=<staging-domain>
# STAGING_CF_ID=<staging-cloudfront-distribution-id>

# Cloudflare — DNS management (optional, one-time setup)
# CLOUDFLARE_API_TOKEN=<api-token>
#
# No API keys are currently required. KJV scripture is bundled.
# NRSVUE is not distributable — if you have a local copy or use
# the nrsvue-source tool, place files at data/translations/nrsvue/.
